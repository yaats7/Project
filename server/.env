# Replace this with your real Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Gemini model used for category + sentiment enrichment
GEMINI_MODEL=gemini-2.5-flash

# Port the backend listens on
PORT=3001

# How many feedback rows are sent to Gemini per request
ENRICH_BATCH_SIZE=20
